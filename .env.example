# Admin panel password (leave unset locally to skip login during development)
ADMIN_PASSWORD=

# Optional: separate session secret. If unset, ADMIN_PASSWORD is used as the session value.
SESSION_SECRET=

# Optional: SMTP credentials for download email notifications.
# If any of these are missing, notifications are silently skipped.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# Required on Vercel (the filesystem there is read-only outside /tmp).
# Leave unset locally to fall back to data/clients.json.
# Install a Redis integration from the Vercel Marketplace to get these.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Required on Vercel for file/screenshot uploads (same read-only filesystem reason).
# Leave unset locally to fall back to public/uploads.
# Created automatically when you add Vercel Blob storage to the project.
BLOB_READ_WRITE_TOKEN=
